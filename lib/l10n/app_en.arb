    "description": "A simple greeting message"
  },

  "welcomeUser": "Welcome, {name}!",
  "@welcomeUser": {
    "description": "A welcome message with user name parameter",
    "placeholders": {
      "name": {
        "type": "String",
        "example": "Alice"
      }
    }
  },

  "itemCount": "{count} items",
  "@itemCount": {
    "description": "Display item count",
    "placeholders": {
      "count": {
        "type": "int",
        "example": "5"
      }
